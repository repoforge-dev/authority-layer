    "validate": "tsc -p tsconfig.json && node dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "enforcement",
    "budget",
    "rate-limit",
    "safety"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}