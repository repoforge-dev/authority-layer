{
  "name": "@authority-layer/core",
  "version": "0.1.0",
  "description": "Hard execution and budget limits for autonomous agents — enforced locally.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
