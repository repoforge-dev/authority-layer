{
  "name": "authority-layer",
  "version": "0.1.5",
  "description": "Runtime guardrails for AI agents that enforce token budgets, loop limits, and tool rate limits locally.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "authority-layer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "tsc -p tsconfig.json && node dist/index.js",
    "example": "node ../../examples/run.js",
    "doctor": "node dist/cli.js doctor",
    "simulate": "node dist/cli.js simulate",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "ai-agents",
    "agent-runtime",
    "runtime-guardrails",
    "llm-guardrails",
    "token-cost-control",
    "execution-limits",
    "rate-limiting",
    "autonomous-agents",
    "agentic-ai",
    "ai-infrastructure",
    "runtime-safety",
    "typescript",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/032383justin/authority-layer.git"
  },
  "homepage": "https://github.com/032383justin/authority-layer",
  "bugs": {
    "url": "https://github.com/032383justin/authority-layer/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}